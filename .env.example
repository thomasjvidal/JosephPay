# ═══════════════════════════════════════════════════════════
#  JosephPay — Variáveis de Ambiente
#  Copie este arquivo para ".env" e preencha os valores.
#  NUNCA commite o arquivo .env no git.
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
# Painel Supabase → Settings → API
SUPABASE_URL=https://XXXXXXXXXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Asaas ────────────────────────────────────────────────────
# Painel Asaas → Configurações → Integrações → API Key
# Sandbox:  https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/api/v3
ASAAS_API_KEY=$aact_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
ASAAS_API_URL=https://sandbox.asaas.com/api/v3

# ── Anthropic (Chat IA) ──────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Evolution API (WhatsApp) ─────────────────────────────────
# URL base da sua instância Evolution API (auto-hospedada ou nuvem)
# Instância: nome que você criou no Evolution Dashboard
EVOLUTION_API_URL=https://evo.seudominio.com
EVOLUTION_API_KEY=B6D711FCDE4D4FD5936544120E713976
EVOLUTION_INSTANCE=josephpay

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

# ── Frontend (preencher também no início do index.html) ──────
# Estas duas variáveis precisam ser copiadas manualmente para
# as constantes SUPABASE_URL e SUPABASE_ANON no index.html
# (Supabase Anon Key é pública — pode ficar no HTML)
# SUPABASE_ANON_KEY é a mesma que acima
